# Telegram API Credentials (get from https://my.telegram.org )
API_ID=12345678
API_HASH=your_api_hash_here

# Bot Token (get from @BotFather on Telegram)
BOT_TOKEN=1234567890:ABCdefGhIJKlmNoPQRsTUVwxyZ

# MongoDB Connection String (get from https://www.mongodb.com/cloud/atlas/register )
# ‼ Crucial Warning: Do NOT use special characters like @, :, or / in your password. It will break the URI later. Stick to letters and numbers!
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/?retryWrites=true&w=majority
DB_NAME=spotigram_db

# Optional: Private Telegram Channel ID for logging (e.g., -1001234567890)
LOG_CHANNEL=0

BOT_USERNAME=YourSpotigramBot
ADMIN_IDS=123456789,987654321